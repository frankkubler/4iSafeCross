# Ignore les fichiers inutiles dans l'image Docker
.git
.gitignore
.gitlab-ci.yml
.gitlab-ci-docker.yml
.gitlab-ci-nuitka.yml
.venv
__pycache__
*.pyc
*.pyo
*.pyd
.Python
*.log
.pytest_cache
.mypy_cache
.nuitka
dist/
*.dist/
*.build/
*.tar.gz
*.zip
logs/*
!logs/.gitkeep
detections/
README.md
*.md
!CYTHON_README.md
.github/
scripts/
# Fichiers de build Cython (intermediaires)
build/
*.c
*.so
