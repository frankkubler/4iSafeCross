# Variables d'environnement sensibles — NE PAS commiter .env dans Git
# Copier ce fichier en .env et renseigner les valeurs réelles.
#
# Chargement automatique via systemd (EnvironmentFile=/chemin/vers/.env)
# ou manuellement : export $(cat .env | xargs)

TELEGRAM_TOKEN=<token_du_bot_telegram>
TELEGRAM_CHAT_ID=<id_du_groupe_de_supervision>
